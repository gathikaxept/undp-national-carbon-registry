# =============================================================================
# national-api service environment variables
# Used by: national (port 3000) and stats (port 3100) containers
# =============================================================================
# Copy to .env.national and fill in real values. NEVER commit .env.national.

# -----------------------------------------------------------------------------
# Admin / bootstrap accounts (created on first startup)
# Replace with real operational email addresses before deploying
# -----------------------------------------------------------------------------
rootEmail=admin@example.org
cfAdminEmail=cf-admin@example.org
exComAdminEmail=excom-admin@example.org

# -----------------------------------------------------------------------------
# Country / region configuration
# -----------------------------------------------------------------------------
systemCountryCode=NG
systemCountryName=CountryX
systemContinentName=CountryX
countryClimateFundName=CountryX Climate Fund (Pvt) Ltd
name=CountryX Region
climateFundName=CountryX Climate Fund
exComName=Executive Committee
Ministry=
Department=
logoBase64=
CONTACT_EMAIL=contactus@example.org
MINISTER_NAME_AND_DESIGNATION=\nHonorable Minister X\nMinister\nMinistry of Environment, Forestry & Tourism

# -----------------------------------------------------------------------------
# Host / URL
# -----------------------------------------------------------------------------
HOST=http://localhost:3030           # Public URL of the frontend (used in emails, documents)
BACKEND_HOST=http://localhost:3000   # URL of the national-api reachable from other containers

# -----------------------------------------------------------------------------
# JWT Secrets  [REQUIRED — service will not start without these]
# Use: openssl rand -hex 32   to generate each value
# -----------------------------------------------------------------------------
USER_JWT_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_JWT_SECRET=replace-with-a-different-long-random-string
ADMIN_JWT_SECRET=replace-with-yet-another-long-random-string

EXPIRES_IN=7200
REFRESH_TOKEN_EXPIRES_IN=12h

# -----------------------------------------------------------------------------
# Email / SMTP  [REQUIRED — service will not start without these]
# Set IS_EMAIL_DISABLED=true for local development
# -----------------------------------------------------------------------------
IS_EMAIL_DISABLED=true
DISABLE_LOW_PRIORITY_EMAIL=true
EMAILPREFIX=
SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
SMTP_USERNAME=AKIAIOSFODNN7EXAMPLEEXAMPLE   # Replace with your SES IAM access key
SMTP_PASSWORD=                       # SES SMTP password

# -----------------------------------------------------------------------------
# Async queue  [REQUIRED — service will not start without this]
# For local dev (ASYNC_OPERATIONS_TYPE=Database), any non-empty string works
# For AWS: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>.fifo
# -----------------------------------------------------------------------------
ASYNC_QUEUE_NAME=local-not-used

# -----------------------------------------------------------------------------
# Cache (TTL in milliseconds / max record count)
# -----------------------------------------------------------------------------
CACHE_PROJECT_TTL=60000
CACHE_PROJECT_MAX=100
CACHE_RETIREMENT_TTL=60000
CACHE_RETIREMENT_MAX=100
CACHE_ORGANISATION_TTL=60000
CACHE_ORGANISATION_MAX=100

# -----------------------------------------------------------------------------
# Rate limiting (requests / duration in seconds)
# -----------------------------------------------------------------------------
RATE_LIMIT_PROJECT_LIMIT=100
RATE_LIMIT_PROJECT_DURATION=60
RATE_LIMIT_RETIREMENT_LIMIT=100
RATE_LIMIT_RETIREMENT_DURATION=60
RATE_LIMIT_ORGANISATION_LIMIT=100
RATE_LIMIT_ORGANISATION_DURATION=60
