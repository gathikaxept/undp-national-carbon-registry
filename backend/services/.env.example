# =============================================================================
# Carbon Registry – Backend Environment Variables
# =============================================================================
# Copy this file to .env.dev or .env.prod and fill in real values.
# NEVER commit files containing real secrets to version control.
# Variables marked [REQUIRED] will cause the service to refuse to start if unset.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime / Stage
# -----------------------------------------------------------------------------
STAGE=local                         # local | dev | prod
NODE_ENV=development                # development | production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=hquser
DB_PASSWORD=changeme
DB_NAME=carbondev
# Set to "true" only for local dev or test — never in production (use migrations instead)
DB_SYNCHRONIZE=false

# -----------------------------------------------------------------------------
# JWT Secrets  [REQUIRED — no default, service will not start without these]
# -----------------------------------------------------------------------------
USER_JWT_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_JWT_SECRET=replace-with-a-different-long-random-string
ADMIN_JWT_SECRET=replace-with-yet-another-long-random-string

# JWT expiry
EXPIRES_IN=7200
REFRESH_TOKEN_EXPIRES_IN=12h

# -----------------------------------------------------------------------------
# Email / SMTP  [REQUIRED — no default, service will not start without these]
# -----------------------------------------------------------------------------
SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
SMTP_USERNAME=AKIAIOSFODNN7EXAMPLE   # IAM access key for SES — replace with your own
SMTP_PASSWORD=                       # SES SMTP password (different from IAM secret key)
SOURCE_EMAIL=noreply@example.org
IS_EMAIL_DISABLED=true               # Set to false in production
DISABLE_LOW_PRIORITY_EMAIL=true
EMAILPREFIX=
HOST_ADDRESS=Address <br>Region, Country Zipcode
EMAIL_CONFIG_SET=

# -----------------------------------------------------------------------------
# Async Queue  [REQUIRED — no default, service will not start without this]
# -----------------------------------------------------------------------------
# For local dev with ASYNC_OPERATIONS_TYPE=Database, any non-empty string works.
# For AWS SQS: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>.fifo
ASYNC_QUEUE_NAME=local-not-used
ASYNC_OPERATIONS_TYPE=Database      # Database | Queue

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILE_SERVICE=LOCAL                  # LOCAL | S3
S3_COMMON_BUCKET=carbon-common-dev

# -----------------------------------------------------------------------------
# Location Service
# -----------------------------------------------------------------------------
LOCATION_SERVICE=FILE               # FILE | OPENSTREET | MAPBOX
MAPBOX_PK=                          # Mapbox public token (required if LOCATION_SERVICE=MAPBOX)
OPENSTREET_QUERY=false

# -----------------------------------------------------------------------------
# Ledger
# -----------------------------------------------------------------------------
LEDGER_TYPE=NONE                    # NONE | QLDB
carbon_dev_common=carbon-common-dev

# -----------------------------------------------------------------------------
# Host URLs
# -----------------------------------------------------------------------------
HOST=http://localhost:3030           # Public URL of the frontend (used in emails, documents)
BACKEND_HOST=http://localhost:3000   # Internal URL of the national-api (used by replicator)

# -----------------------------------------------------------------------------
# Registry Sync (optional — disabled by default)
# -----------------------------------------------------------------------------
SYNC_ENABLE=false
SYNC_ENDPOINT=
SYNC_API_TOKEN=

# -----------------------------------------------------------------------------
# ITMO System Integration (optional — disabled by default)
# -----------------------------------------------------------------------------
ITMO_ENABLE=false
ITMO_ENDPOINT=
ITMO_API_KEY=
ITMO_EMAIL=
ITMO_PASSWORD=

# -----------------------------------------------------------------------------
# CADT (CAD Trust) Integration (optional — disabled by default)
# -----------------------------------------------------------------------------
CADTRUST_ENABLE=false
CADTRUST_ENDPOINT=

# -----------------------------------------------------------------------------
# System / Country Configuration
# -----------------------------------------------------------------------------
systemCountryCode=NG
systemCountryName=CountryX
systemContinentName=CountryX
countryClimateFundName=CountryX Climate Fund (Pvt) Ltd
defaultCreditUnit=ITMO
REPORT_YEAR=2024
SYSTEM_TYPE=CARBON_UNIFIED_SYSTEM
SYSTEM_NAME=SystemX
DOMAIN_MAP=false

# -----------------------------------------------------------------------------
# Document Generation
# -----------------------------------------------------------------------------
MINISTER_NAME=Minister X
MINISTER_NAME_AND_DESIGNATION=\nHonorable Minister X\nMinister\nMinistry of Environment
COUNTRY_CAPITAL=Capital X
CONTACT_EMAIL=contactus@example.org

# -----------------------------------------------------------------------------
# Certifier Image
# -----------------------------------------------------------------------------
CERTIFIER_IMAGE=

# -----------------------------------------------------------------------------
# Cache (milliseconds / record count)
# -----------------------------------------------------------------------------
CACHE_PROJECT_TTL=60000
CACHE_PROJECT_MAX=100
CACHE_RETIREMENT_TTL=60000
CACHE_RETIREMENT_MAX=100
CACHE_ORGANISATION_TTL=60000
CACHE_ORGANISATION_MAX=100

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
ENCODE_PASSWORD=false
SALT_ROUNDS=10
MRV_ENDPOINT=
