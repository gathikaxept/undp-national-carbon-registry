{
    "name": "custodian",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build:custodian": "nest build custodian",
        "build:task-monitor": "nest build task-monitor",
        "build:replicator": "nest build replicator",
        "build:all": "concurrently \"yarn build:custodian\" \"yarn build:task-monitor\" \"yarn build:replicator\"",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
        "start": "nest start",
        "start:custodian": "nest start custodian",
        "start:task-monitor": "nest start task-monitor",
        "start:replicator": "nest start replicator",
        "start:all": "concurrently \"yarn start:custodian\" \"yarn start:task-monitor\" \"yarn start:replicator\"",
        "start:debug": "nest start --debug --watch",
        "start:custodian-dev": "nest start custodian --watch",
        "start:task-monitor-dev": "nest start task-monitor --watch",
        "start:replicator-dev": "nest start replicator --watch",
        "start:all-dev": "concurrently \"yarn start:custodian-dev\" \"yarn start:task-monitor-dev\" \"yarn start:replicator-dev\"",
        "start:custodian-prod": "node dist/apps/custodian/main",
        "start:task-monitor-prod": "node dist/apps/task-monitor/main",
        "start:replicator-prod": "node dist/apps/replicator/main",
        "start:all-prod": "concurrently \"yarn start:custodian-prod\" \"yarn start:task-monitor-prod\" \"yarn start:replicator-prod\"",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./apps/custodian/test/jest-e2e.json"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.740.0",
        "@hashgraph/sdk": "^2.59.0",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/bull": "^11.0.2",
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/platform-express": "^11.0.7",
        "@nestjs/swagger": "^11.0.3",
        "@nestjs/typeorm": "^11.0.0",
        "axios": "^1.7.9",
        "bull": "^4.16.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "fs": "^0.0.1-security",
        "luxon": "^3.5.0",
        "nest-winston": "^1.10.2",
        "nestjs-i18n": "^10.5.0",
        "pdfkit": "^0.16.0",
        "pg": "^8.13.1",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.20",
        "uuid": "^11.0.5",
        "winston": "^3.17.0",
        "xlsx": "^0.18.5",
        "moment": "^2.30.1",
        "exceljs": "^4.4.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.1",
        "@types/pdfkit": "^0.13.9",
        "@types/supertest": "^6.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "concurrently": "^8.2.2",
        "eslint": "^8.0.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.5.0",
        "prettier": "^3.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/libs/",
            "<rootDir>/apps/"
        ],
        "moduleNameMapper": {
            "^@app/core(|/.*)$": "<rootDir>/libs/core/src/$1",
            "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
        }
    }
}
