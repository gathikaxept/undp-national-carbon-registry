# =============================================================================
# Database credentials
# Used by: docker-compose db service (Postgres image) + all backend services
# =============================================================================
# Copy to .env.db and fill in real values. NEVER commit .env.db.

# Shared between the Postgres image and backend services
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=changeme

# Postgres image requires these exact variable names
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
PSQL_USERNAME=postgres
